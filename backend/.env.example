# Configuración de la base de datos
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=elijeser
DB_PORT=3306

# JWT Secret (cambiar en producción)
JWT_SECRET=tu_jwt_secret_key_muy_segura_aqui

# Puerto del servidor
PORT=3000

# Ambiente (development, production)
NODE_ENV=development

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info

# CORS Origins (separar con comas)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://elige-ser.onrender.com
